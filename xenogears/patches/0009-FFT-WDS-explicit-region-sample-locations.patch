 #include "FFTInstr.h"
 #include "VGMSamp.h"
 #include "PSXSPU.h"
+#include <set>
+
+namespace {
+bool isValidPSXFilterShiftByteLocal(uint8_t b) {
+  uint8_t filter = b >> 4;
+  uint8_t shift  = b & 0x0F;
+  return filter <= 4 && shift <= 0x0C;
+}
+
+bool isValidPSXFlagByteLocal(uint8_t b) {
+  return (b & 0xF8) == 0;
+}
+
+uint32_t scanFFTWdsReferencedSampleSize(const RawFile* file, uint32_t sampleStart, uint32_t hardEnd) {
+  if (sampleStart + 16 > hardEnd) {
+    return 0;
+  }
+
+  uint32_t cursor = sampleStart;
+  while (cursor + 16 <= hardEnd) {
+    uint8_t filterShift = file->readByte(cursor);
+    uint8_t flagByte = file->readByte(cursor + 1);
+
+    if (!isValidPSXFilterShiftByteLocal(filterShift) || !isValidPSXFlagByteLocal(flagByte)) {
+      return 0;
+    }
+
+    cursor += 16;
+    if (flagByte & 1) {
+      return cursor - sampleStart;
+    }
+  }
+
+  return 0;
+}
+}  // namespace
+
 
