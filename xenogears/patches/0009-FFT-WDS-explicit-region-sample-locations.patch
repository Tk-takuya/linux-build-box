+    const uint32_t rgnOffset = offset() + sizeof(WdsHdr) + (i * sizeof(WdsRgnData));
+    readBytes(rgnOffset, sizeof(WdsRgnData), &rgnData);
+
+    uint32_t relSampOffset = rgnData.ptBody;
+    if (version == VERSION_WDS) {
