+
+void FFTTrack::emitRuntimeProgram(uint32_t offset, uint32_t length, uint8_t program, const std::string &sEventName) {
+  activeProgram = program;
+  uint32_t midiProgram = (static_cast<uint32_t>(currentBank) << 7) | program;
+  addProgramChange(offset, length, midiProgram, true, sEventName);
 }
 
 
