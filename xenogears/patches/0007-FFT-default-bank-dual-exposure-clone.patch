+        dstRgn->keyLow = srcRgn->keyLow;
+        dstRgn->keyHigh = srcRgn->keyHigh;
+        dstRgn->velLow = srcRgn->velLow;
+        dstRgn->velHigh = srcRgn->velHigh;
+        dstRgn->unityKey = srcRgn->unityKey;
+        dstRgn->coarseTune = srcRgn->coarseTune;
+        dstRgn->fineTune = srcRgn->fineTune;
+        dstRgn->loop = srcRgn->loop;
+        dstRgn->sampNum = srcRgn->sampNum;
+        dstRgn->sampOffset = srcRgn->sampOffset;
+        dstRgn->sampDataLength = srcRgn->sampDataLength;
+        dstRgn->sampCollPtr = srcRgn->sampCollPtr != nullptr ? srcRgn->sampCollPtr : source->sampColl;
+        dstRgn->pan = srcRgn->pan;
+        dstRgn->attack_time = srcRgn->attack_time;
+        dstRgn->attack_transform = srcRgn->attack_transform;
+        dstRgn->hold_time = srcRgn->hold_time;
+        dstRgn->decay_time = srcRgn->decay_time;
+        dstRgn->sustain_level = srcRgn->sustain_level;
+        dstRgn->sustain_time = srcRgn->sustain_time;
+        dstRgn->release_transform = srcRgn->release_transform;
+        dstRgn->release_time = srcRgn->release_time;
+        dstRgn->setAttenuation(srcRgn->attenDb());
+        dstRgn->setLfoVibFreqHz(srcRgn->lfoVibFreqHz());
+        dstRgn->setLfoVibDepthCents(srcRgn->lfoVibDepthCents());
+        dstRgn->setLfoVibDelaySeconds(srcRgn->lfoVibDelaySeconds());
+        dstInstr->addRgn(dstRgn);
+      }
+    }
+  }
+
+  ~FFTBankCloneInstrSet() override {
+    sampColl = nullptr;
+    for (auto *instr : aInstrs)
+      delete instr;
+    aInstrs.clear();
+  }
+};
 
