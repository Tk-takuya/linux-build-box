--- /dev/null
+++ b/src/main/formats/FFT/FFTMatcher.h
@@ -0,0 +1,78 @@
+#pragma once
+
+#include <map>
+#include "Matcher.h"
+#include "VGMSeq.h"
+#include "VGMInstrSet.h"
+#include "FFTSeq.h"
+#include "FFTColl.h"
+
+class FFTMatcher : public Matcher {
+ public:
+  explicit FFTMatcher(Format *format) : Matcher(format) {}
+
+ protected:
+  bool onNewSeq(VGMSeq *seq) override {
+    auto *fftSeq = dynamic_cast<FFTSeq *>(seq);
+    if (!fftSeq)
+      return false;
+    m_seqs.insert({fftSeq->id(), fftSeq});
+    tryBuildForSeq(fftSeq);
+    return true;
+  }
+
+  bool onNewInstrSet(VGMInstrSet *instrSet) override {
+    uint32_t id = instrSet->id();
+    if (id == static_cast<uint32_t>(-1))
+      return false;
+    if (!m_instrsets.contains(id))
+      m_instrsets[id] = instrSet;
+
+    for (auto &[defaultId, seq] : m_seqs) {
+      auto *fftSeq = dynamic_cast<FFTSeq *>(seq);
+      if (!fftSeq || !fftSeq->assocColls.empty())
+        continue;
+      if (defaultId == id || fftSeq->referencedBanks().contains(static_cast<uint16_t>(id)))
+        tryBuildForSeq(fftSeq);
+    }
+    return true;
+  }
+
+ private:
+  void tryBuildForSeq(FFTSeq *seq) {
+    if (!seq || !seq->assocColls.empty())
+      return;
+
+    uint32_t defaultId = seq->id();
+    auto defaultIt = m_instrsets.find(defaultId);
+    if (defaultIt == m_instrsets.end())
+      return;
+
+    for (auto bank : seq->referencedBanks()) {
+      if (bank == 0 || bank == defaultId)
+        continue;
+      if (!m_instrsets.contains(bank))
+        return;
+    }
+
+    auto *coll = new FFTColl();
+    coll->setName(seq->name());
+    coll->useSeq(seq);
+    coll->addInstrSetWithBank(defaultIt->second, 0);
+
+    for (auto bank : seq->referencedBanks()) {
+      if (bank == 0 || bank == defaultId)
+        continue;
+      auto it = m_instrsets.find(bank);
+      if (it != m_instrsets.end())
+        coll->addInstrSetWithBank(it->second, bank);
+    }
+
+    if (!coll->load()) {
+      delete coll;
+    }
+  }
+
+  std::multimap<uint32_t, VGMSeq *> m_seqs;
+  std::map<uint32_t, VGMInstrSet *> m_instrsets;
+};
