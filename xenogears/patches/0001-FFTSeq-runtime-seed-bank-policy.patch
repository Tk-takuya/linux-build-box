+
+void FFTTrack::insertMidiProgram(uint8_t program, uint32_t absTime, bool emitBank) {
+  if (readMode != READMODE_CONVERT_TO_MIDI || pMidiTrack == nullptr)
+    return;
+  if (emitBank)
+    pMidiTrack->insertBankSelect(channel, currentBank, absTime);
+  pMidiTrack->aEvents.push_back(new ProgChangeEvent(pMidiTrack, channel, absTime, program));
 }
 
+void FFTTrack::emitRuntimeProgram(uint32_t offset, uint32_t length, uint8_t program,
+                                  const std::string &sEventName, bool seedToTickZero) {
+  activeProgram = program;
+  const uint32_t uiLength = std::max(length, 1u);
+  const bool seedNow = seedToTickZero && !runtimeSeeded;
+
+  if (readMode == READMODE_ADD_TO_UI) {
+    bool isNewOffset = onEvent(offset, uiLength);
+    recordSeqEvent<ProgChangeSeqEvent>(isNewOffset, seedNow ? 0 : getTime(), program, offset, uiLength, sEventName);
+  } else if (readMode == READMODE_CONVERT_TO_MIDI) {
+    insertMidiProgram(program, seedNow ? 0 : getTime(), seedNow);
+  }
+
+  runtimeSeeded = true;
+}
 
