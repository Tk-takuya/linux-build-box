+const FFTPercussionEntry *FFTSeq::findPercussionEntry(uint8_t triggerNote) const {
+  for (const auto &entry : percussionTable) {
+    if (entry.triggerNote == triggerNote)
+      return &entry;
+  }
+  return nullptr;
+}
 
